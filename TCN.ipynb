import pandas as pd
import numpy as np
import torch
import torch.nn as nn
import torch.optim as optim
from torch.utils.data import Dataset, DataLoader
from sklearn.model_selection import train_test_split
from sklearn.metrics import f1_score, precision_score, recall_score, log_loss
from torch.nn.utils import weight_norm
import gc

# Check for CUDA device availability
device = torch.device("cuda" if torch.cuda.is_available() else "cpu")
print(f"Using device: {device}")

# --- Step 1: Data Loading & Preprocessing ---
print("Loading data files...")
try:
    orders = pd.read_csv('orders.csv')
    order_products_prior = pd.read_csv('order_products__prior.csv')
    order_products_train = pd.read_csv('order_products__train.csv')
except FileNotFoundError:
    print("Error: orders.csv, order_products__prior.csv, or order_products__train.csv not found.")
    print("Please make sure these files are in the same directory as your script or provide the full path.")
    exit()

orders_prior = orders[orders['eval_set'] == 'prior']
orders_train = orders[orders['eval_set'] == 'train']

print("Merging data...")
user_prod_history = pd.merge(orders_prior, order_products_prior, on='order_id', how='left')
user_sequences = user_prod_history.groupby('user_id')['product_id'].apply(list).to_dict()

all_products = pd.concat([user_prod_history['product_id'], order_products_train['product_id']]).unique()
prod_to_int = {prod_id: i + 1 for i, prod_id in enumerate(all_products)}
vocab_size = len(prod_to_int) + 1
all_products_list = list(prod_to_int.keys())

final_train = pd.merge(order_products_train, orders_train, on='order_id', how='left')
valid_users_with_history = list(user_sequences.keys())
final_train = final_train[final_train['user_id'].isin(valid_users_with_history)]

user_reordered_prods = final_train[final_train['reordered'] == 1].groupby('user_id')['product_id'].apply(set).to_dict()
user_not_reordered_prods = final_train[final_train['reordered'] == 0].groupby('user_id')['product_id'].apply(set).to_dict()

del orders, orders_prior, user_prod_history, order_products_prior, order_products_train
gc.collect()

print("Preparing data for the model...")

# --- Step 2: Custom PyTorch Dataset Class with Negative Sampling ---
class InstacartDataset(Dataset):
    def __init__(self, users, user_sequences, user_reordered_prods, user_not_reordered_prods, prod_to_int, all_products_list, sequence_length=20, num_neg_samples=4):
        self.users = users
        self.user_sequences = user_sequences
        self.user_reordered_prods = user_reordered_prods
        self.user_not_reordered_prods = user_not_reordered_prods
        self.prod_to_int = prod_to_int
        self.all_products_list = all_products_list
        self.sequence_length = sequence_length
        self.num_neg_samples = num_neg_samples
        self.user_to_idx = {user_id: i for i, user_id in enumerate(self.users)}

    def __len__(self):
        return len(self.users)

    def __getitem__(self, idx):
        user_id = self.users[idx]

        # 1. Input Sequence (User History)
        input_sequence = self.user_sequences.get(user_id, [])
        if len(input_sequence) > self.sequence_length:
            input_sequence = input_sequence[-self.sequence_length:]

        input_sequence_int = [self.prod_to_int.get(prod_id, 0) for prod_id in input_sequence]
        padding = [0] * (self.sequence_length - len(input_sequence_int))
        input_sequence_int.extend(padding)

        # 2. Get Positive and Negative Samples
        candidate_prods = []
        labels = []

        positive_prods_for_user = list(self.user_reordered_prods.get(user_id, set()))

        if positive_prods_for_user:
            pos_prod = np.random.choice(positive_prods_for_user)
            candidate_prods.append(pos_prod)
            labels.append(1.0)
        else:
            # If no reordered products for this user, we must still return a tensor of the right size.
            # We'll treat this as a batch of pure negative samples.
            random_prod = np.random.choice(self.all_products_list)
            candidate_prods.append(random_prod)
            labels.append(0.0)

        negative_pool = list(set(self.all_products_list) - set(input_sequence) - set(positive_prods_for_user))

        num_neg_to_sample = self.num_neg_samples
        if len(negative_pool) < num_neg_to_sample:
            neg_prods = np.random.choice(list(set(self.all_products_list) - set(input_sequence)), num_neg_to_sample, replace=True)
        else:
            neg_prods = np.random.choice(negative_pool, num_neg_to_sample, replace=False)

        candidate_prods.extend(neg_prods)
        labels.extend([0.0] * num_neg_to_sample)

        candidate_prods_int = [self.prod_to_int.get(prod_id, 0) for prod_id in candidate_prods]

        return (
            torch.tensor(input_sequence_int, dtype=torch.long),
            torch.tensor(candidate_prods_int, dtype=torch.long),
            torch.tensor(labels, dtype=torch.float)
        )

# Custom Collate Function for Negative Sampling
def collate_fn(batch):
    batch = [item for item in batch if item is not None]
    if not batch:
        return None, None, None

    sequences, candidates, labels = zip(*batch)

    sequences = torch.stack(sequences)
    candidates = torch.stack(candidates)
    labels = torch.stack(labels)

    return sequences, candidates, labels

# --- Step 3: TCN Model Architecture ---
class Chomp1d(nn.Module):
    def __init__(self, chomp_size):
        super(Chomp1d, self).__init__()
        self.chomp_size = chomp_size

    def forward(self, x):
        return x[:, :, :-self.chomp_size].contiguous()

class TemporalBlock(nn.Module):
    def __init__(self, n_inputs, n_outputs, kernel_size, stride, dilation, padding, dropout=0.2):
        super(TemporalBlock, self).__init__()
        self.conv1 = weight_norm(nn.Conv1d(n_inputs, n_outputs, kernel_size,
                                           stride=stride, padding=padding, dilation=dilation))
        self.chomp1 = Chomp1d(padding)
        self.relu1 = nn.ReLU()
        self.dropout1 = nn.Dropout(dropout)
        self.conv2 = weight_norm(nn.Conv1d(n_outputs, n_outputs, kernel_size,
                                           stride=stride, padding=padding, dilation=dilation))
        self.chomp2 = Chomp1d(padding)
        self.relu2 = nn.ReLU()
        self.dropout2 = nn.Dropout(dropout)
        self.net = nn.Sequential(self.conv1, self.chomp1, self.relu1, self.dropout1,
                                 self.conv2, self.chomp2, self.relu2, self.dropout2)
        self.downsample = nn.Conv1d(n_inputs, n_outputs, 1) if n_inputs != n_outputs else None
        self.relu = nn.ReLU()
        self.init_weights()

    def init_weights(self):
        self.conv1.weight.data.normal_(0, 0.01)
        self.conv2.weight.data.normal_(0, 0.01)
        if self.downsample is not None:
            self.downsample.weight.data.normal_(0, 0.01)

    def forward(self, x):
        out = self.net(x)
        res = x if self.downsample is None else self.downsample(x)
        return self.relu(out + res)

class TemporalConvNet(nn.Module):
    def __init__(self, num_inputs, num_channels, kernel_size=2, dropout=0.2):
        super(TemporalConvNet, self).__init__()
        layers = []
        num_levels = len(num_channels)
        for i in range(num_levels):
            dilation_size = 2 ** i
            in_channels = num_inputs if i == 0 else num_channels[i-1]
            out_channels = num_channels[i]
            layers += [TemporalBlock(in_channels, out_channels, kernel_size, stride=1, dilation=dilation_size,
                                     padding=(kernel_size-1) * dilation_size, dropout=dropout)]
        self.network = nn.Sequential(*layers)

    def forward(self, x):
        return self.network(x)

class TCNRecommender(nn.Module):
    def __init__(self, vocab_size, embed_size, num_channels, kernel_size, dropout):
        super(TCNRecommender, self).__init__()
        self.user_embedding = nn.Embedding(vocab_size, embed_size, padding_idx=0)
        self.item_embedding = nn.Embedding(vocab_size, embed_size, padding_idx=0)
        self.tcn = TemporalConvNet(embed_size, num_channels, kernel_size=kernel_size, dropout=dropout)
        self.linear = nn.Linear(num_channels[-1] + embed_size, 1)

    def forward(self, user_history_inputs, candidate_item_inputs):
        user_history_embedded = self.user_embedding(user_history_inputs).permute(0, 2, 1)
        user_history_features = self.tcn(user_history_embedded)
        user_history_representation = user_history_features[:, :, -1]

        candidate_item_embedded = self.item_embedding(candidate_item_inputs)

        num_candidates = candidate_item_embedded.size(1)
        user_representation_expanded = user_history_representation.unsqueeze(1).expand(-1, num_candidates, -1)

        combined_features = torch.cat([user_representation_expanded, candidate_item_embedded], dim=2)
        logits = self.linear(combined_features)

        return logits.squeeze(-1)

# --- Step 4: Model Training and Evaluation Loop ---
embedding_size = 100
num_channels = [100, 100, 100]
kernel_size = 2
dropout = 0.2
epochs = 5
batch_size = 32
sequence_length = 20
num_neg_samples = 4

dataset = InstacartDataset(list(user_sequences.keys()), user_sequences, user_reordered_prods, user_not_reordered_prods, prod_to_int, all_products_list, sequence_length, num_neg_samples)
train_users, val_users = train_test_split(dataset.users, test_size=0.2, random_state=42)

train_dataset_subset = torch.utils.data.Subset(dataset, [dataset.user_to_idx[uid] for uid in train_users])
val_dataset_subset = torch.utils.data.Subset(dataset, [dataset.user_to_idx[uid] for uid in val_users])

train_loader = DataLoader(train_dataset_subset, batch_size=batch_size, shuffle=True, collate_fn=collate_fn)
val_loader = DataLoader(val_dataset_subset, batch_size=batch_size, shuffle=False, collate_fn=collate_fn)

model = TCNRecommender(vocab_size, embedding_size, num_channels, kernel_size, dropout).to(device)
optimizer = optim.Adam(model.parameters(), lr=0.001)
criterion = nn.BCEWithLogitsLoss()

print("\n--- Training the TCN Model ---")
for epoch in range(epochs):
    model.train()
    total_loss = 0
    try:
        for inputs, candidates, labels in train_loader:
            if inputs is None: continue
            inputs, candidates, labels = inputs.to(device), candidates.to(device), labels.to(device)

            outputs = model(inputs, candidates)
            loss = criterion(outputs, labels)

            optimizer.zero_grad()
            loss.backward()
            optimizer.step()

            total_loss += loss.item()

        print(f"Epoch {epoch+1}/{epochs}, Training Loss: {total_loss / len(train_loader):.4f}")
    except ZeroDivisionError:
        print(f"Epoch {epoch+1}/{epochs}, Training Loss: N/A (no data in loader)")
        continue

    model.eval()
    val_losses = []
    y_true_all = []
    y_pred_all = []

    with torch.no_grad():
        for inputs, candidates, labels in val_loader:
            if inputs is None: continue
            inputs, candidates, labels = inputs.to(device), candidates.to(device), labels.to(device)

            outputs = model(inputs, candidates)

            val_loss = criterion(outputs, labels)
            val_losses.append(val_loss.item())

            preds = (torch.sigmoid(outputs) > 0.5).int()
            y_true_all.extend(labels.cpu().numpy().flatten())
            y_pred_all.extend(preds.cpu().numpy().flatten())

    if len(val_losses) > 0:
        avg_val_loss = np.mean(val_losses)
        f1 = f1_score(y_true_all, y_pred_all, average='micro')
        precision = precision_score(y_true_all, y_pred_all, average='micro')
        recall = recall_score(y_true_all, y_pred_all, average='micro')

        print(f"Validation Loss: {avg_val_loss:.4f}, F1-Score: {f1:.4f}, Precision: {precision:.4f}, Recall: {recall:.4f}")
    else:
        print("Validation metrics: N/A (no data in loader)")

print("TCN Model training completed.")
print("\n--- All operations completed. ---")
